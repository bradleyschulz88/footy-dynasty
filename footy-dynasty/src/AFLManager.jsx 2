            <div className="font-['Bebas_Neue'] text-5xl text-[#3B82F6]">{pct}%</div>
            <div className="text-[10px] text-[#94A3B8] uppercase tracking-wider">Camp Complete</div>
          </div>
        </div>
        <div className="mt-4">
          <div className="h-3 rounded-full overflow-hidden" style={{background:"#DBEAFE"}}>
            <div className="h-full rounded-full transition-all duration-500" style={{width:`${pct}%`, background:"linear-gradient(90deg,#3B82F6,#6366F1)"}} />
          </div>
        </div>
      </div>

      {/* Squad readiness */}
      <div className="grid grid-cols-3 gap-3">
        {[
          { label: "Squad Rating", value: squadAvg, color: "#E89A4A", icon: "⭐" },
          { label: "Avg Fitness",  value: avgFit,   color: avgFit>=85?"#4AE89A":avgFit>=70?"#E89A4A":"#E84A6F", icon: "💚" },
          { label: "Avg Form",     value: avgForm,  color: avgForm>=70?"#4AE89A":"#E89A4A", icon: "📈" },
        ].map(s=>(
          <div key={s.label} className="rounded-2xl p-4 text-center" style={{background:"white", border:"1px solid #E2E8F0"}}>
            <div className="text-xl mb-1">{s.icon}</div>
            <div className="font-['Bebas_Neue'] text-3xl" style={{color:s.color}}>{s.value}</div>
            <div className="text-[9px] font-black uppercase tracking-widest text-[#94A3B8]">{s.label}</div>
          </div>
        ))}
      </div>

      {isComplete ? (
        <div className="rounded-2xl p-6 text-center" style={{background:"#F0FDF4", border:"1.5px solid #BBF7D0"}}>
          <div className="text-4xl mb-2">🏁</div>
          <div className="font-['Bebas_Neue'] text-2xl text-[#16A34A]">Pre-Season Complete!</div>
          <div className="text-sm text-[#64748B] mt-1">Head to the Hub to start Round 1.</div>
        </div>
      ) : (
        <>
          {/* Training Activities */}
          <div>
            <div className="text-[10px] font-black uppercase tracking-[0.2em] text-[#94A3B8] mb-3">Choose A Training Activity</div>
            <div className="grid grid-cols-1 md:grid-cols-2 gap-3">
              {ACTIVITIES.map(act => {
                const canDo = (career.day||0) + act.days <= PRE_SEASON_DAYS;
                return (
                  <button key={act.id} onClick={()=>canDo && onActivity(act.id)} disabled={!canDo}
                    className="text-left p-4 rounded-2xl transition-all"
                    style={{background:"white", border:`1.5px solid ${canDo ? "#E2E8F0" : "#F1F5F9"}`, opacity: canDo ? 1 : 0.5}}
                    onMouseEnter={e=>{if(canDo){e.currentTarget.style.borderColor=act.color;e.currentTarget.style.background=act.color+"08";}}}
                    onMouseLeave={e=>{e.currentTarget.style.borderColor="#E2E8F0";e.currentTarget.style.background="white";}}>
                    <div className="flex items-center gap-3">
                      <span className="text-2xl">{act.icon}</span>
                      <div className="flex-1">
                        <div className="font-bold text-sm text-[#0F172A]">{act.label}</div>
                        <div className="text-[10px] text-[#64748B] mt-0.5">{act.effect}</div>
                      </div>
                      <div className="text-right flex-shrink-0">
                        <div className="font-['Bebas_Neue'] text-xl" style={{color: act.color}}>{act.days}d</div>
                        <div className="text-[9px] text-[#94A3B8]">
                          {canDo ? "Available" : "Not enough time"}
                        </div>
                      </div>
                    </div>
                  </button>
                );
              })}
            </div>
          </div>

          {/* Skip day */}
          <div className="flex items-center gap-3">
            <button onClick={onAdvance} className="flex-1 py-3 rounded-xl font-semibold text-sm text-[#64748B] transition-all" style={{background:"#F8FAFC", border:"1px solid #E2E8F0"}}>
              ⏩ Skip 1 Day ({dayOfSeason((career.day||0)+1)})
            </button>
            <button onClick={()=>{for(let i=0;i<7;i++) onAdvance();}} className="py-3 px-5 rounded-xl font-semibold text-sm text-[#64748B] transition-all" style={{background:"#F8FAFC", border:"1px solid #E2E8F0"}}>
              Skip Week
            </button>
          </div>

          {rookies > 0 && (
            <div className="rounded-xl p-3 flex items-center gap-3" style={{background:"#F0FDF4", border:"1px solid #BBF7D0"}}>
              <span>🌱</span>
              <div className="text-sm text-[#16A34A] font-medium">{rookies} rookie{rookies>1?"s":""} in squad — try <strong>Youth Integration</strong> to give them a head start.</div>
            </div>
          )}
        </>
      )}

      {/* Recent training news */}
      {career.news.filter(n=>n.text?.includes("complete")).slice(0,3).map((n,i)=>(
        <div key={i} className="flex gap-3 p-3 rounded-xl text-sm" style={{background:"#F8FAFC", border:"1px solid #E2E8F0"}}>
          <span className="text-[#3B82F6]">✓</span>
          <span className="text-[#475569]">{n.text}</span>
        </div>
      ))}
    </div>
  );
}

// ============================================================================
// CALENDAR TAB — Season schedule with dates
// ============================================================================
function CalendarTab({ career, club, league }) {
  const totalRounds = career.fixtures.length;
  const currentRd = career.week;
  const today = career.day || 0;

  // Build calendar: pre-season + each round with dates
  const MONTHS = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];

  const phases = [
    {
      label: "Pre-Season",
      icon: "🏋️",
      color: "#3B82F6",
      start: 0,
      end: PRE_SEASON_DAYS,
      startDate: dayOfSeason(0),
      endDate: dayOfSeason(PRE_SEASON_DAYS - 1),
      status: today >= PRE_SEASON_DAYS ? "done" : today > 0 ? "active" : "upcoming",
    },
    ...career.fixtures.map((_, i) => {
      const dayStart = PRE_SEASON_DAYS + i * DAYS_PER_ROUND;
      const dayEnd   = dayStart + DAYS_PER_ROUND - 1;
      const st = today > dayEnd ? "done" : today >= dayStart ? "active" : "upcoming";
      // Find my match in this round
      const rd = career.fixtures[i];
      const myM = rd ? rd.find(m => m.home === career.clubId || m.away === career.clubId) : null;
      const opp = myM ? findClub(myM.home === career.clubId ? myM.away : myM.home) : null;
      const isHome = myM ? myM.home === career.clubId : null;
      const hasResult = myM && myM.result;
      return {
        label: `Round ${i + 1}`,
        icon: "🏉",
        color: st === "active" ? "#E89A4A" : st === "done" ? "#4AE89A" : "#94A3B8",
        startDate: dayOfSeason(dayStart),
        endDate: dayOfSeason(dayEnd),
        status: st,
        opp, isHome, hasResult,
        result: myM?.result,
        round: i,
      };
    }),
    {
      label: "Finals",
      icon: "🏆",
      color: "#E89A4A",
      startDate: dayOfSeason(PRE_SEASON_DAYS + totalRounds * DAYS_PER_ROUND),
      endDate: "TBD",
      status: career.inFinals ? "active" : career.week >= totalRounds ? "upcoming" : "future",
    },
  ];

  const statusBadge = (s) => {
    if (s === "done")    return { bg:"#F0FDF4", border:"#BBF7D0", text:"#16A34A", label:"Done" };
    if (s === "active")  return { bg:"#FFF7ED", border:"#FED7AA", text:"#EA580C", label:"Now" };
    return { bg:"#F8FAFC", border:"#E2E8F0", text:"#94A3B8", label:"Upcoming" };
  };

  return (
    <div className="space-y-4">
      <div>
        <h2 className="font-['Bebas_Neue'] text-3xl text-[#0F172A]">{career.season} SEASON CALENDAR</h2>
        <p className="text-sm text-[#64748B]">Pre-season starts 1 Dec · {totalRounds} rounds home-and-away · Finals TBD</p>
      </div>

      {/* Summary strip */}
      <div className="grid grid-cols-3 gap-3">
        {[
          { label: "Total Rounds", value: totalRounds, color: "#4ADBE8" },
          { label: "Current Round", value: career.phase === "preseason" ? "Pre-Season" : currentRd || "—", color: "#E89A4A" },
          { label: "Today", value: dayOfSeason(today), color: "#4AE89A" },
        ].map(s => (
          <div key={s.label} className="rounded-2xl p-3 text-center" style={{background:"white", border:"1px solid #E2E8F0"}}>
            <div className="font-['Bebas_Neue'] text-2xl" style={{color:s.color}}>{s.value}</div>
            <div className="text-[9px] font-black uppercase tracking-widest text-[#94A3B8]">{s.label}</div>
          </div>
        ))}
      </div>

      {/* Timeline */}
      <div className="space-y-2">
        {phases.map((ph, i) => {
          const badge = statusBadge(ph.status);
          return (
            <div key={i} className="rounded-2xl p-4 transition-all"
              style={{background: ph.status==="active" ? "#FFF7ED" : "white", border:`1.5px solid ${ph.status==="active" ? "#FED7AA" : "#E2E8F0"}`}}>
              <div className="flex items-center gap-3">
                {/* Timeline dot */}
                <div className="w-8 h-8 rounded-full flex items-center justify-center flex-shrink-0 text-base"
                  style={{background: `${ph.color}18`, color: ph.color}}>
                  {ph.status === "done" ? "✓" : ph.icon}
                </div>
                <div className="flex-1 min-w-0">
                  <div className="flex items-center gap-2 flex-wrap">
                    <span className="font-bold text-sm">{ph.label}</span>
                    <span className="text-[10px] px-2 py-0.5 rounded-full font-bold" style={{background:badge.bg, color:badge.text, border:`1px solid ${badge.border}`}}>{badge.label}</span>
                    {ph.opp && (
                      <span className="text-[10px] text-[#64748B]">vs {ph.opp.short} {ph.isHome ? "🏠" : "✈️"}</span>
                    )}
                  </div>
                  <div className="text-[11px] text-[#94A3B8] mt-0.5">{ph.startDate} – {ph.endDate}</div>
                </div>
                {/* Result or score */}
                {ph.hasResult && ph.result && (
                  <div className="text-right flex-shrink-0">
                    <div className="font-['Bebas_Neue'] text-lg" style={{color: (ph.isHome ? ph.result.hScore > ph.result.aScore : ph.result.aScore > ph.result.hScore) ? "#4AE89A" : "#E84A6F"}}>
                      {ph.isHome ? ph.result.hScore : ph.result.aScore} – {ph.isHome ? ph.result.aScore : ph.result.hScore}
                    </div>
                    <div className="text-[9px] font-bold text-[#94A3B8]">
                      {(ph.isHome ? ph.result.hScore > ph.result.aScore : ph.result.aScore > ph.result.hScore) ? "WIN" : (ph.result.hScore === ph.result.aScore ? "DRAW" : "LOSS")}
                    </div>
                  </div>
                )}
              </div>
            </div>
          );
        })}
      </div>
    </div>
  );
}
