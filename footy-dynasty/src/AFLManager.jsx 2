              <Pill color="#4ADBE8">Round {career.week + 1}</Pill>
              <Pill color={posColor}>#{myLadderPos || "—"} on Ladder</Pill>
              {myRow && <Pill color="#64748B">{myRow.W}W {myRow.L}L {myRow.D}D</Pill>}
