  const isComplete = career.phase !== "preseason";

  const ACTIVITIES = [
    { id: "fitness",   label: "Fitness Camp",           icon: "🏃", color: "#4AE89A", days: 7,  effect: "Endurance +2, Fitness +3–6 all players" },
    { id: "skills",    label: "Skills Training",         icon: "🎯", color: "#4ADBE8", days: 7,  effect: "Kicking, Handball, Marking +1–3 each" },
    { id: "tactics",   label: "Tactics Sessions",        icon: "📋", color: "#A78BFA", days: 5,  effect: "Decision +2 for all players" },
    { id: "scrimmage", label: "Practice Match",          icon: "⚽", color: "#E89A4A", days: 7,  effect: "Form +5–10, reveals positional gaps" },
