          {navItems.map(it => {
            const Icon = it.icon;
            const active = screen === it.key;
            return (
              <button key={it.key} onClick={()=>changeScreen(it.key)} className="flex-1 flex flex-col items-center justify-center py-2 gap-0.5 transition-all"
                style={{color: active ? "#E89A4A" : "#94A3B8"}}>
                <div className={`p-1.5 rounded-xl transition-all ${active ? "bg-[#E89A4A]/12" : ""}`}>
                  <Icon className="w-5 h-5" />
