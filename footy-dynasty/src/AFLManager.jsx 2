                <div className="flex justify-end"><button onClick={()=>acquire(p)} disabled={!canAfford} className={canAfford ? `${css.btnPrimary} text-xs px-3 py-1.5` : "px-3 py-1.5 rounded-lg text-xs bg-[#F1F5F9] text-[#94A3B8]"}>{canAfford ? "Acquire" : "Too dear"}</button></div>
