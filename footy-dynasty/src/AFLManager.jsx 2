// ── DATE SYSTEM ──────────────────────────────────────────────────────────
// Season calendar: Dec 1 = day 0 (pre-season)
// Pre-season: Dec 1 – Feb 28 (90 days, ~13 weeks)
// Round 1 starts: Mar 1 (day 90)
// Each round = 7 days
// Finals follow immediately after last round
const SEASON_START_MONTH = 12; // December
const PRE_SEASON_DAYS = 90;    // Dec + Jan + Feb
const DAYS_PER_ROUND = 7;

function dayOfSeason(day) {
  // day 0 = Dec 1
  const months = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];
  const dayCounts = [31,28,31,30,31,30,31,31,30,31,30,31];
  let m = 11; // Dec = index 11
  let d = 1 + day;
  while (d > dayCounts[m]) {
    d -= dayCounts[m];
    m = (m + 1) % 12;
  }
  return `${d} ${months[m]}`;
}

function isPreSeason(day) { return day < PRE_SEASON_DAYS; }
function currentRound(day) { return Math.floor((day - PRE_SEASON_DAYS) / DAYS_PER_ROUND); }
function dayOfRound(day) { return (day - PRE_SEASON_DAYS) % DAYS_PER_ROUND; }


