  return (
    <div className="anim-in space-y-5">
      {/* Hero Banner */}
      <div className="rounded-2xl overflow-hidden relative" style={{minHeight:100, background:`linear-gradient(135deg, ${club.colors[0]}55 0%, #F1F5F9 60%)`, border:"1px solid #E2E8F0"}}>
        <div className="absolute inset-0" style={{background:`radial-gradient(ellipse at 80% 50%, ${club.colors[1]}18, transparent 65%)`}} />
